{
  "name": "explorer-engine",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo root for Explorer Engine — a generic, data-driven 3D object exploration engine. Scaffold only (P0-T1); no engine code yet.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "workspaces": [
    "packages/core",
    "packages/renderer-three",
    "packages/ui-webcomponents",
    "packages/input-dom",
    "packages/plugin-sdk",
    "packages/schema",
    "packages/plugins/*",
    "apps/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @explorer-engine/playground",
    "typecheck": "tsc -p tsconfig.json && npm run typecheck --workspaces --if-present",
    "lint": "eslint . && depcruise packages",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "check:arch": "node scripts/check-core-headless.mjs",
    "test": "vitest run --passWithNoTests",
    "build": "npm run build --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "ci": "npm run typecheck && npm run lint && npm run format && npm run check:arch && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "dependency-cruiser": "18.1.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
