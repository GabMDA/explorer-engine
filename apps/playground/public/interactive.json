{
  "schemaVersion": "1.0",
  "meta": { "title": "Interactive Demo", "defaultLocale": "en" },
  "model": { "src": "models/indexed.glb" },
  "camera": { "controls": { "minDistance": 1, "maxDistance": 20 } },
  "components": [
    { "id": "crown", "label": "Crown", "nodes": [{ "explorerId": "crown" }] },
    { "id": "gear-left", "label": "Gear (left)", "nodes": [{ "explorerId": "gear" }], "pickTarget": "gears" },
    { "id": "gear-top", "label": "Gear (top)", "nodes": [{ "explorerId": "gear2" }], "pickTarget": "gears" },
    {
      "id": "gears",
      "label": "Gears",
      "nodes": [{ "explorerId": "gear" }, { "explorerId": "gear2" }],
      "group": "internals"
    }
  ],
  "focus": {
    "padding": 1.6,
    "dimOthers": true,
    "dimOpacity": 0.12,
    "outline": { "color": "#ffd166", "thickness": 1.5 },
    "transition": { "duration": 700, "easing": "easeInOut" }
  },
  "hotspots": [
    {
      "id": "hs-crown",
      "label": "Crown",
      "anchor": { "kind": "component", "id": "crown" },
      "action": { "type": "focus", "target": { "kind": "component", "id": "crown" } }
    },
    {
      "id": "hs-gears",
      "label": "Gears",
      "anchor": { "kind": "component", "id": "gears" },
      "action": { "type": "focus", "target": { "kind": "component", "id": "gears" } }
    },
    {
      "id": "hs-base",
      "label": "Base marker",
      "anchor": { "kind": "position", "position": [0, -0.9, 0] },
      "occludable": false,
      "action": { "type": "emit", "event": "base:ping" }
    }
  ]
}
